# Nmap: run from tree root with compile_commands.json, e.g.
#   bear --append -- make -j"$(nproc)"
#   ./maint/run-clang-tidy.sh
Checks: >
  clang-analyzer-*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  performance-*,
  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-function-cognitive-complexity
WarningsAsErrors: ''
HeaderFilterRegex: '.*'
FormatStyle: none
